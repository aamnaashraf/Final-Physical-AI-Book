# Environment Variables for RAG Chatbot Backend

# Google Gemini API Key (get from https://makersuite.google.com/app/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# Pinecone API Key (get from https://app.pinecone.io/)
PINECONE_API_KEY=your_pinecone_api_key_here

# Pinecone Environment (e.g., us-east-1-aws, gcp-starter)
PINECONE_ENVIRONMENT=us-east-1

# Pinecone Index Name (default: rag-chatbot-768)
PINECONE_INDEX_NAME=rag-chatbot-768
