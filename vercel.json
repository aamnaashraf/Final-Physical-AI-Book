{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/chat.py": {
      "runtime": "python3.9",
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "/api/chat.py"
    }
  ]
}
